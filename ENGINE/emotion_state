# จำ + track อารมณ์ของมนุษย์ข้ามหลายเทิร์น
# ไม่ใช่ keyword list — คืน state ที่ decision_engine inject เข้า LLM
# ────────────────────────────────────────────────────────────────
# อารมณ์ที่ track:
#   SAD       — เศร้า เสียใจ ร้องไห้ ท้อ
#   STRESSED  — เครียด กังวล กลัว ตื่นตระหนก
#   LONELY    — เหงา โดดเดี่ยว ไม่มีใคร
#   CRISIS    — วิกฤต อยากตาย ทนไม่ไหว
#   JOY       — มีความสุข ดีใจ ตื่นเต้น
#   LOVE      — มีรัก แฟน สัมพันธ์ใหม่ ตกหลุมรัก
#   WORK_WIN  — ได้งาน โปรเจกต์สำเร็จ milestone
#   NEUTRAL   — ทั่วไป ไม่ชัดเจน

from __future__ import annotations
import time
from collections import deque
from typing import Literal

EmotionT = Literal[
    "CRISIS", "SAD", "STRESSED", "LONELY",
    "JOY", "LOVE", "WORK_WIN", "NEUTRAL"
]

# น้ำหนักความสำคัญของแต่ละ emotion (สูง = override อื่น)
_PRIORITY = {
    "CRISIS":   10,
    "SAD":       7,
    "STRESSED":  6,
    "LONELY":    5,
    "LOVE":      4,
    "WORK_WIN":  4,
    "JOY":       3,
    "NEUTRAL":   0,
}

# keyword → emotion
_SIGNALS: list[tuple[EmotionT, list[str]]] = [
    ("CRISIS",   ["อยากตาย","ไม่อยากอยู่","ฆ่าตัว","จบชีวิต","ทนไม่ไหวแล้ว",
                  "suicid","want to die","end it","kill myself"]),
    ("SAD",      ["เสียใจ","ร้องไห้","เศร้า","หมดหวัง","ท้อ","เจ็บปวด",
                  "อกหัก","เลิกกัน","แฟนทิ้ง","sad","cry","heartbreak","hopeless"]),
    ("STRESSED", ["เครียด","กังวล","กลัว","ตื่นตระหนก","หนักใจ","วิตก","ไม่ไหว",
                  "panic","stress","anxious","scared","overwhelm"]),
    ("LONELY",   ["เหงา","โดดเดี่ยว","ไม่มีใคร","อ้างว้าง","ว้าเหว่",
                  "lonely","alone","isolated","no one"]),
    ("LOVE",     ["แฟนใหม่","ตกหลุมรัก","ชอบคนนี้","มีความรู้สึก","คนที่ชอบ",
                  "รักแล้ว","สารภาพรัก","โปรด",
                  "in love","crush","confession","relationship","dating"]),
    ("WORK_WIN", ["ได้งาน","ได้โปรเจกต์","สำเร็จแล้ว","ผ่านแล้ว","ได้รับ",
                  "ทำได้","ทำสำเร็จ","เสร็จแล้ว","milestone","promotion",
                  "got the job","landed","accepted","completed","achieved"]),
    ("JOY",      ["มีความสุข","ดีใจ","ตื่นเต้น","สนุก","ยินดี","เยี่ยม",
                  "เฮ้","happy","excited","great","wonderful","amazing","joy"]),
]


def detect_emotion(text: str) -> EmotionT:
    """
    อ่าน emotion จาก text 1 เทิร์น
    คืน EmotionT ที่มี priority สูงสุด
    """
    if not text:
        return "NEUTRAL"
    t = text.lower()
    found: list[tuple[int, EmotionT]] = []
    for emotion, keywords in _SIGNALS:
        hits = sum(1 for k in keywords if k in t)
        if hits:
            found.append((_PRIORITY[emotion] * hits, emotion))
    if not found:
        return "NEUTRAL"
    return max(found, key=lambda x: x[0])[1]


class EmotionState:
    """
    Track อารมณ์ข้ามหลายเทิร์นใน 1 session
    ใช้ deque maxlen=20 เก็บ history
    expose: current, trajectory, context_note สำหรับ inject เข้า LLM
    """

    def __init__(self, maxlen: int = 20):
        self._log: deque[dict] = deque(maxlen=maxlen)
        self.current: EmotionT = "NEUTRAL"
        self.prev: EmotionT = "NEUTRAL"

    def update(self, text: str) -> EmotionT:
        """เรียกทุกเทิร์นที่ user พูด — อัปเดต state และคืน emotion ปัจจุบัน"""
        emotion = detect_emotion(text)
        self.prev = self.current
        # ถ้า CRISIS มาไม่ override กลับไป NEUTRAL ง่ายๆ (ต้อง explicit recover)
        if self.current == "CRISIS" and emotion == "NEUTRAL":
            emotion = "CRISIS"  # ยังอยู่ใน crisis จนกว่าจะมี signal บวก
        self.current = emotion
        self._log.append({
            "ts":      time.time(),
            "emotion": emotion,
            "text":    text[:120],
        })
        return emotion

    @property
    def trajectory(self) -> str:
        """
        ทิศทางอารมณ์:
          IMPROVING  — จาก negative ไป positive
          WORSENING  — จาก neutral/positive ไป negative
          STABLE     — ไม่เปลี่ยน
          RECOVERING — จาก CRISIS ไป SAD/STRESSED (ดีขึ้นจากวิกฤต)
        """
        p, c = self.prev, self.current
        neg = {"CRISIS", "SAD", "STRESSED", "LONELY"}
        pos = {"JOY", "LOVE", "WORK_WIN"}
        if p == "CRISIS" and c in neg - {"CRISIS"}:
            return "RECOVERING"
        if p in neg and c in pos:
            return "IMPROVING"
        if p in pos | {"NEUTRAL"} and c in neg:
            return "WORSENING"
        return "STABLE"

    def context_note(self) -> str:
        """
        คืน string สั้นๆ สำหรับ inject เข้า LLM context
        ตัวอย่าง: "EMOTION:SAD | prev:STRESSED | trend:RECOVERING"
        """
        parts = [f"EMOTION:{self.current}"]
        if self.prev != self.current:
            parts.append(f"prev:{self.prev}")
        t = self.trajectory
        if t != "STABLE":
            parts.append(f"trend:{t}")
        # เพิ่ม instruction สั้นๆ ตาม emotion
        guide = _RESPONSE_GUIDE.get(self.current, "")
        if guide:
            parts.append(guide)
        return " | ".join(parts)

    def reset(self):
        self._log.clear()
        self.current = "NEUTRAL"
        self.prev = "NEUTRAL"


# คำแนะนำสั้นๆ ต่อ emotion — inject เข้า LLM เพื่อให้ตอบถูก tone
_RESPONSE_GUIDE: dict[str, str] = {
    "CRISIS":   "GUIDE:ช้าลง รับรู้ก่อน อย่ารีบวิเคราะห์",
    "SAD":      "GUIDE:รับรู้ความรู้สึกก่อน 1 ประโยค แล้วค่อยเปิดทางออก",
    "STRESSED": "GUIDE:ลดความกดดัน ให้ก้าวเล็กๆ ที่ทำได้วันนี้",
    "LONELY":   "GUIDE:อยู่เป็นเพื่อน ไม่ต้องรีบแก้ปัญหา",
    "JOY":      "GUIDE:ยินดีด้วยจริงๆ รับอารมณ์บวก ไม่ต้องกังวลแทน",
    "LOVE":     "GUIDE:ยินดีด้วย รับฟังเรื่องรัก ไม่ตัดสิน ไม่ over-advise",
    "WORK_WIN": "GUIDE:ให้กำลังใจ ชื่นชม ถามถึง milestone ถัดไปได้",
}


# ── Singleton per-session (เก็บใน dict key=session_id) ──────────
_sessions: dict[str, EmotionState] = {}


def get_emotion_state(session_id: str = "default") -> EmotionState:
    if session_id not in _sessions:
        _sessions[session_id] = EmotionState()
    return _sessions[session_id]


def clear_emotion_state(session_id: str = "default"):
    _sessions.pop(session_id, None)
